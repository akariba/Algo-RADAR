# Copy this to .env and fill in your values — never commit .env

FLASK_SECRET_KEY=change-me-32-chars-random-string

# RDS PostgreSQL
DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/sybil_db

# AWS
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# SES
SES_SENDER_EMAIL=noreply@sybilradar.com
APP_BASE_URL=https://sybilradar.com

# Token expiry in seconds
EMAIL_TOKEN_EXPIRY=86400
